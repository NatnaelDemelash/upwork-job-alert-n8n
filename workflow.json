{
  "name": "⚡ Upwork Job Alert — AI Filtered",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const job = $input.first().json;\n\nconst title = job.job_title || 'No title';\nconst snippet = (job.job_snippet || '').slice(0, 180);\nconst date = job.job_date || 'Unknown';\nconst link = job.job_link || '#';\n\nconst message = [\n  '━━━━━━━━━━━━━━━━━━',\n  '⚡*UPWORK JOB ALERT*',\n  '━━━━━━━━━━━━━━━━━━',\n  '',\n  `💼 *${title}*`,\n  '',\n  `🎯 ${snippet}...`,\n  '',\n  `🗓 *Posted:* ${date}`,\n  '',\n  `🚀 [Apply Now](${link})`,\n  '',\n  '━━━━━━━━━━━━━━━━━━',\n  '🤖 _Filtered by your n8n bot_'\n].join('\\n');\n\nreturn [{ json: { message } }];"
      },
