    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst organicResults = data.organic_results || [];\n\n// Keep only Upwork job links\nconst upworkJobs = organicResults.filter(result => \n  result.link && \n  result.link.includes('upwork.com/freelance-jobs/apply')\n);\n\nreturn upworkJobs.map(job => ({\n  json: {\n    title: job.title,\n    link: job.link,\n    snippet: job.snippet,\n    date: job.date || 'unknown'\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1472, 128],
      "id": "32c326c9-36ba-4df4-bcd5-d72b2ded8688",
      "name": "🧹 Extract Upwork Jobs"
    },
    {
      "parameters": {
        "jsCode": "const results = [];\n\nfor (const item of $input.all()) {\n  const dateStr = item.json.date || '';\n  \n  // Pass if posted today, yesterday, 1 day ago, 2 days ago, or hours ago\n  const isRecent = \n    dateStr.includes('hour') ||\n    dateStr.includes('just') ||\n    dateStr.includes('minute') ||\n    dateStr.includes('1 day') ||\n    dateStr.includes('2 day') ||\n    dateStr.includes('today') ||\n    dateStr.includes('yesterday');\n  \n  if (isRecent) {\n    results.push(item);\n  }\n}\n\nreturn results.length > 0 ? results : [];"
      },
